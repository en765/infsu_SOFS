@model FitnessStudio.Web.ViewModels.ClanarinaIndexViewModel

@{
    ViewData["Title"] = "Članarine i uplate";
}

<h1>Članarine i uplate</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<form method="get" asp-action="Index" class="mb-3">
    <div class="d-flex gap-2">
        <input type="text"
               name="search"
               value="@Model.Search"
               placeholder="Pretraži po članu, paketu ili statusu"
               class="form-control" />

        <button type="submit" class="btn btn-outline-primary">Pretraži</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova članarina</a>
</p>

<h3>Članarine</h3>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Član</th>
            <th>Paket</th>
            <th>Datum početka</th>
            <th>Datum završetka</th>
            <th>Status</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var clanarina in Model.Clanarine)
        {
            var isSelected = Model.SelectedClanarinaId == clanarina.ClanarinaId;

            <tr class="@(isSelected ? "table-primary" : "")">
                <td>@clanarina.ClanarinaId</td>
                <td>@Model.Clanovi.GetValueOrDefault(clanarina.ClanId, "Nepoznat član")</td>
                <td>@Model.Paketi.GetValueOrDefault(clanarina.PaketId, "Nepoznat paket")</td>
                <td>@clanarina.DatumPocetka.ToString("dd.MM.yyyy.")</td>
                <td>@clanarina.DatumZavrsetka.ToString("dd.MM.yyyy.")</td>
                <td>@clanarina.Status</td>
                <td>
                    <a asp-action="Index"
                       asp-route-search="@Model.Search"
                       asp-route-selectedClanarinaId="@clanarina.ClanarinaId"
                       class="btn btn-sm btn-info">
                        Uplate
                    </a>
                    <a asp-action="Edit"
                       asp-route-id="@clanarina.ClanarinaId"
                       class="btn btn-sm btn-warning">
                        Uredi
                    </a>
                    <a asp-action="Delete"
                       asp-route-id="@clanarina.ClanarinaId"
                       class="btn btn-sm btn-danger">
                        Obriši
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<h3 class="mt-4">Uplate za odabranu članarinu</h3>

@if (Model.SelectedClanarinaId.HasValue)
{
    <p><strong>Odabrana članarina ID:</strong> @Model.SelectedClanarinaId</p>

    @if (Model.Uplate.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Datum</th>
                    <th>Iznos</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var uplata in Model.Uplate)
                {
                    <tr>
                        <td>@uplata.UplataId</td>
                        <td>@uplata.Datum.ToString("dd.MM.yyyy.")</td>
                        <td>@uplata.Iznos</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            Za odabranu članarinu nema evidentiranih uplata.
        </div>
    }
}
else
{
    <div class="alert alert-secondary">
        Nije odabrana nijedna članarina.
    </div>
}