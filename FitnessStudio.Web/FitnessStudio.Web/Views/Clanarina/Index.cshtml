@model FitnessStudio.Web.ViewModels.ClanarinaIndexViewModel

@{
    ViewData["Title"] = "Članarine i uplate";
}

<h1>Članarine i uplate</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<form method="get" asp-action="Index" class="mb-3">
    <div class="d-flex gap-2">
        <input type="text"
               name="search"
               value="@Model.Search"
               placeholder="Pretraži po članu, paketu ili statusu"
               class="form-control" />

        <button type="submit" class="btn btn-outline-primary">Pretraži</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova članarina</a>
</p>

<h3>Članarine</h3>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Član</th>
            <th>Paket</th>
            <th>Datum početka</th>
            <th>Datum završetka</th>
            <th>Status</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var clanarina in Model.Clanarine)
        {
            var isSelected = Model.SelectedClanarinaId == clanarina.ClanarinaId;

            <tr id="clanarina-@clanarina.ClanarinaId" class="@(isSelected ? "selected-row" : "")">
                <td>@clanarina.ClanarinaId</td>
                <td>@Model.Clanovi.GetValueOrDefault(clanarina.ClanId, "Nepoznat član")</td>
                <td>@Model.Paketi.GetValueOrDefault(clanarina.PaketId, "Nepoznat paket")</td>
                <td>@clanarina.DatumPocetka.ToString("dd.MM.yyyy.")</td>
                <td>@clanarina.DatumZavrsetka.ToString("dd.MM.yyyy.")</td>
                <td>@clanarina.Status</td>
                <td>
                    <a href="@Url.Action("Index", new { search = Model.Search, selectedClanarinaId = clanarina.ClanarinaId })#clanarina-@clanarina.ClanarinaId"
                    class="btn btn-sm btn-info">
                        Detalji
                    </a>
                    <a asp-action="Edit"
                       asp-route-id="@clanarina.ClanarinaId"
                       class="btn btn-sm btn-warning">
                        Uredi
                    </a>
                    <a asp-action="Delete"
                       asp-route-id="@clanarina.ClanarinaId"
                       class="btn btn-sm btn-danger">
                        Obriši
                    </a>
                </td>
            </tr>

            @if (isSelected)
            {
                    <tr class="detail-row">
                        <td colspan="7" class="p-0">
                            <div class="detail-box">
                            @if (Model.OdabraniPaketCijena.HasValue)
                            {
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <h5 class="card-title">Sažetak članarine</h5>
                                        <p><strong>Paket:</strong> @Model.OdabraniPaketNaziv</p>
                                        <p><strong>Cijena paketa:</strong> @Model.OdabraniPaketCijena?.ToString("0.00")</p>
                                        <p><strong>Ukupno uplaćeno:</strong> @Model.UkupnoUplaceno.ToString("0.00")</p>
                                        <p><strong>Preostalo za uplatu:</strong> @Model.PreostaloZaUplatu.ToString("0.00")</p>
                                    </div>
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="mb-0">Uplate</h5>
                                <a asp-action="CreateUplata"
                                   asp-route-clanarinaId="@clanarina.ClanarinaId"
                                   class="btn btn-primary btn-sm">
                                    Nova uplata
                                </a>
                            </div>

                            @if (Model.Uplate.Any())
                            {
                                <table class="table table-bordered table-striped mb-0">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Datum</th>
                                            <th>Iznos</th>
                                            <th>Akcije</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var uplata in Model.Uplate)
                                        {
                                            <tr>
                                                <td>@uplata.UplataId</td>
                                                <td>@uplata.Datum.ToString("dd.MM.yyyy.")</td>
                                                <td>@uplata.Iznos.ToString("0.00")</td>
                                                <td>
                                                    <a asp-action="EditUplata"
                                                       asp-route-id="@uplata.UplataId"
                                                       class="btn btn-sm btn-warning">
                                                        Uredi
                                                    </a>
                                                    <a asp-action="DeleteUplata"
                                                       asp-route-id="@uplata.UplataId"
                                                       class="btn btn-sm btn-danger">
                                                        Obriši
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="alert alert-info mb-0">
                                    Za odabranu članarinu nema evidentiranih uplata.
                                </div>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>