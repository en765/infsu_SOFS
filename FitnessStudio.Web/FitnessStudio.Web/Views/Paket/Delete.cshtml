@model FitnessStudio.Domain.Models.Paket

@{
    ViewData["Title"] = "Obriši paket";
}

<h1>Obriši paket</h1>

<div class="alert alert-warning">
    Jeste li sigurni da želite obrisati ovaj paket?
</div>

<div class="mb-3">
    <strong>Naziv:</strong> @Model.Naziv
</div>

<div class="mb-3">
    <strong>Broj treninga:</strong> @Model.BrojTreninga
</div>

<div class="mb-3">
    <strong>Cijena:</strong> @Model.Cijena
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" name="paketId" value="@Model.PaketId" />
    <button type="submit" class="btn btn-danger">Obriši</button>
    <a asp-action="Index" class="btn btn-secondary">Odustani</a>
</form>