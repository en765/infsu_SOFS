@model IEnumerable<FitnessStudio.Domain.Models.Paket>

@{
    ViewData["Title"] = "Paketi";
}

<h1>Paketi</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<form method="get" asp-action="Index" class="mb-3">
    <div class="d-flex gap-2">
        <input type="text"
               name="search"
               value="@ViewBag.Search"
               placeholder="Pretraži po nazivu"
               class="form-control"
               list="paketSuggestions" />

        <datalist id="paketSuggestions">
            @foreach (var naziv in (IEnumerable<string>)ViewBag.PackageNames)
            {
                <option value="@naziv"></option>
            }
        </datalist>

        <button type="submit" class="btn btn-outline-primary">Pretraži</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Novi paket</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Naziv</th>
            <th>Broj treninga</th>
            <th>Cijena</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var paket in Model)
        {
            <tr>
                <td>@paket.PaketId</td>
                <td>@paket.Naziv</td>
                <td>@paket.BrojTreninga</td>
                <td>@paket.Cijena</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@paket.PaketId" class="btn btn-sm btn-warning">Uredi</a>
                    <a asp-action="Delete" asp-route-id="@paket.PaketId" class="btn btn-sm btn-danger">Obriši</a>
                </td>
            </tr>
        }
    </tbody>
</table>